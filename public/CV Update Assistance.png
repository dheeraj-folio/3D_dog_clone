1\":{\"name\":\"3292606821\",\"rule_id\":\"2R2ZeKULgDOJcQSgutNXFT\",\"secondary_exposures\":[],\"value\":{\"show_login_modal\":true},\"id_type\":\"stableID\",\"is_device_based\":true,\"group_name\":\"Test\",\"is_experiment_active\":true,\"is_user_in_experiment\":true,\"allocated_experiment_name\":\"984169274\",\"explicit_parameters\":[\"show_login_modal\"],\"undelegated_secondary_exposures\":[]},\"3396794266\":{\"name\":\"3396794266\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"value\":{\"restore_prompt_on_stop\":false,\"enable_interruption\":false},\"id_type\":\"userID\",\"is_device_based\":false,\"explicit_parameters\":[],\"undelegated_secondary_exposures\":[]},\"3787393990\":{\"name\":\"3787393990\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"value\":{\"should_show_promotion_summary\":true},\"id_type\":\"userID\",\"is_device_based\":false,\"explicit_parameters\":[],\"undelegated_secondary_exposures\":[]},\"1250198438\":{\"name\":\"1250198438\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"value\":{\"in_holdout\":false},\"id_type\":\"userID\",\"is_device_based\":false,\"explicit_parameters\":[],\"undelegated_secondary_exposures\":[]},\"817522959\":{\"name\":\"817522959\",\"rule_id\":\"yorFy4h0p4O1FsvCaXZUI\",\"secondary_exposures\":[{\"gate\":\"2359935467\",\"gateValue\":\"true\",\"ruleID\":\"7eHlIQBwwPonlhH69Pt7Xc\"}],\"value\":{\"enable_inflight_request_reuse\":true,\"block_instant_answer\":false,\"contextual_ia_stream_impl\":false,\"chatgpt-instant-answers-dynamic-config\":{\"fetchers\":[\"habitat\",\"cometset\"],\"total_lookup_timeout_sec\":1,\"regexp_blocklist\":[\"^(hey|hello|hi)$\",\".*hantavirus.*\"],\"autocomplete_fetchers\":[\"habitat\",\"cometset\",\"labrador\"],\"configuration_id\":\"instant-answer-semantic-match-v2-llm\",\"auto_eval_judge_prompt\":\"az://oaisasrchprodscus/oaiwiki/prompts/prompt_similarity_judge_v2.md\",\"db_conversation_load_timeout_sec\":0.5,\"enable_instant_answer_stream\":true,\"enable_inline_conversation\":true,\"enable_auto_eval\":true,\"cometset_cache_configuration_id\":\"instant-answer-semantic-match-v2-llm\",\"cache_lookup_timeout_sec\":0.3,\"cache_ttl_sec\":604800,\"enable_dual_db_read\":true,\"enable_auto_eval_ranking_recall\":false,\"auto_eval_sampling_rate\":0.2,\"auto_eval_model_id\":\"gpt-5.4-2026-03-05\",\"stream_chunk_size\":30,\"enable_single_use_cache_response\":true,\"prefetch_on_keystroke\":true,\"labrador_autocomplete_fetcher_config\":{\"enable_inline_conversation\":true,\"ann_weight\":1,\"bm25_threshold\":0,\"request_timeout_sec\":1,\"lexical_enabled_checks\":[\"number_mismatch\",\"number_symbol_mismatch\",\"script_mismatch\",\"mark_symbol_mismatch\",\"generic_symbol_mismatch\",\"punct_mismatch\",\"math_op_mismatch\",\"not_contains_url\",\"not_contains_email\"],\"retrieval_score_threshold\":0.95,\"lexical_max_length\":200,\"reranker_name\":\"llm\",\"bm25_weight\":0.02,\"retrieval_candidate_count\":20,\"lexical_cutoff_threshold\":0.95,\"ann_threshold\":0.95},\"enable_inflight_request_reuse\":true,\"max_prompt_length\":1000,\"labrador_autocomplete_classifier_config\":{\"renderer\":\"harmony_v4.0.16_chatberry_v5_chatgpt_lpe_toolsv2\",\"max_tokens\":1,\"top_k\":1,\"system_prompt\":\"# Task\\n\\nGiven one user_prompt and a letter-labeled list of candidate_prompts, select the single candidate that is an exact paraphrase of the user prompt. An exact paraphrase preserves the same meaning, intent, entities, constraints, language requirements, and expected answer. It may only differ by grammar, wording, word order, punctuation, capitalization, plurality, spelling variation, or minor phrasing.\\n\\n# Decision Rule\\n\\nReturn a match only when the candidate is a grammatical rewrite or direct paraphrase of the user prompt. Do not select candidates that are merely related, broader, narrower, more specific, less specific, or answerable using similar information. Prefer N over a risky match.\\n\\n# Near-Match Rejects\\n\\nReturn N if the candidate changes the requested action, even if the topic is the same.\\n\\nExamples:\\n\\nwrite != how to write\\nmake != how to make\\nedit != how to edit\\n\\nReturn N if the candidate drops or changes any explicit:\\n\\nconstraint\\nformat\\nlanguage\\naudience\\nlocation\\ndate\\nquantity\\nmodel\\npersonal/contextual detail\\n\\n# Context And Instruction Sensitivity\\n\\nReturn N if the candidate changes grammatical person or ownership, such as:\\n\\nI / you / we\\nmy / your / our\\nme / us / them\\n\\nExamples:\\n\\nWhat am I looking for in a partner != What are you looking for in a partner\\nIs my dog sick != Is your dog sick\\n\\nReturn N if the candidate removes unresolved references such as:\\n\\nit\\nthis\\nthat\\nthese\\nthose\\n\\nExamples:\\n\\nWill steaming my face help it != Will steaming my face help\\n\\nReturn N if the candidate drops user instructions such as:\\n\\nhow to solve\\nno spoilers\\nstep by step\\ndo not make it AI generated\\nexplain why\\nwith examples\\n\\n# Specific-Instance Sensitivity\\n\\nReturn N if the user prompt refers to a specific instance, current state, observed behavior, or singular entity, and the candidate rewrites it as a generic fact question about a class or category.\\n\\nExamples:\\n\\nis the gold fish sleeping != do goldfish sleep\\nis my dog sick != what are signs of dog illness\\n\\n# Time-Sensitive Rejects\\n\\nReturn N if the prompt asks about:\\n\\ntoday\\ncurrent\\nlatest\\nleading\\npolling\\nwho will win\\nthis year\\nnext manager\\nprices\\nlive events\\nschedules\\nlaws\\npenalties\\n\\nor other information that can change over time, unless the candidate preserves the same time/location scope exactly.\\n\\n# Constraint Sensitivity\\n\\nSmall wording changes are allowed, but return N if the candidate drops narrowing words such as:\\n\\nmain\\ntoday\\ncurrent\\nlatest\\nin Europe\\nin the U.S.\\nsettings\\nnothing else\\nfree\\nbest\\nunder\\n\\nor any specific location, date, quantity, or model.\\n\\n# Output-Format Sensitivity\\n\\nReturn N if the user requests a specific response format or restriction, such as:\\n\\nnothing else\\nshort answer\\nverses only\\ndraw\\nAPA style\\ndetailed explanation\\n\\nand the candidate does not preserve it.\\n\\n# Input Format\\n\\nuser_prompt:\\ncandidate_prompts:\\nA.\\nB.\\nC.\\n...\\n\\nCandidate order is a retrieval prior only. It must never override the exact-paraphrase requirement.\\nN is reserved for no-match and is not a candidate.\\n\\n# Positive Examples\\n\\nuser_prompt: dogs eat cat treats?\\ncandidate_prompts:\\nA. can I give cat treats to my dog?\\nB. can dogs eat cat food?\\nC. are cat treats safe for cats?\\nAnswer: A\\n\\nuser_prompt: is the capital of Sweden?\\ncandidate_prompts:\\nA. Stockholm is the capital of which country?\\nB. what is Sweden's capital city?\\nC. tell me about Stockholm\\nAnswer: B\\n\\nuser_prompt: hello into Korean\\ncandidate_prompts:\\nA. translate hello to Korean\\nB. how do you say hello in Korean and explain pronunciation\\nC. translate hello into Japanese\\nAnswer: A\\n\\nuser_prompt: can you make a mind map\\ncandidate_prompts:\\nA. How can I make a mind map\\nB. can you create a mind map\\nAnswer: B\\n\\nuser_prompt: give me the verses from the bible that speak against homosexuality. Nothing else, just the verses of the bible\\ncandidate_prompts:\\nA. What verses in the bible are against homosexuality\\nB. Give only bible verses that speak against homosexuality\\nAnswer: A\\n\\nuser_prompt: what am I looking for in a partner\\ncandidate_prompts:\\nA. What are you looking for in a partner\\nB. What am I seeking in a partner\\nAnswer: B\\n\\n# Negative Examples\\n\\nuser_prompt: can you make a mind map\\ncandidate_prompts:\\nA. How can I make a mind map\\nB. what is a mind map\\nAnswer: A\\n\\nuser_prompt: how to respond to this email:\\ncandidate_prompts:\\nA. How to respond to an email\\nB. how to write professional emails\\nAnswer: A\\n\\nuser_prompt: is the gold fish sleeping\\ncandidate_prompts:\\nA. Does gold fish sleep\\nB. How do goldfish sleep?\\nAnswer: A\\n\\nuser_prompt: what am I looking for in a partner\\ncandidate_prompts:\\nA. What are you looking for in a partner\\nB. What qualities do people usually want in a partner?\\nAnswer: A\\n\\n# Response Format\\n\\nReturn exactly one uppercase character:\\n\\nan existing candidate label, such as A, B, or C\\nN if no candidate is an exact paraphrase, or if you are uncertain\\n\\nDo not output explanations, JSON, markdown, punctuation, multiple letters, lowercase letters, or extra text.\",\"enable_logprobs\":true,\"classifier_model\":\"gpt-5.4-mini-2026-03-17-cia-ev3\"}},\"enable_instant_answers\":false,\"enable_inflight_request_reuse_on_follow_up_turns\":false},\"id_type\":\"userID\",\"is_device_based\":false,\"group_name\":\"llm reranker\",\"is_experiment_active\":true,\"is_user_in_experiment\":true,\"allocated_experiment_name\":\"3764157420\",\"explicit_parameters\":[\"chatgpt-instant-answers-dynamic-config\",\"enable_inflight_request_reuse\"],\"undelegated_secondary_exposures\":[]},\"347810050\":{\"name\":\"347810050\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"value\":{\"stripe_provider_loading_screen_enabled\":false,\"nonblocking_checkout_nav_flush_enabled\":false,\"skip_pricing_to_checkout_loading_screen_enabled\":false},\"id_type\":\"userID\",\"is_device_based\":false,\"explicit_parameters\":[],\"undelegated_secondary_exposures\":[]},\"499412252\":{\"name\":\"499412252\",\"rule_id\":\"default\",\"secondary_exposures\":[{\"gate\":\"3239069106\",\"gateValue\":\"false\",\"ruleID\":\"1LKRhqtrdS5Ah2YiL7PH03:4.00:1\"}],\"value\":{\"enable_ogp\":false,\"pdf_based_preview_enabled\":false,\"resume_preview_enabled\":false},\"id_type\":\"userID\",\"is_device_based\":false,\"explicit_parameters\":[],\"undelegated_secondary_exposures\":[{\"gate\":\"3239069106\",\"gateValue\":\"false\",\"ruleID\":\"1LKRhqtrdS5Ah2YiL7PH03:4.00:1\"}]},\"2670916218\":{\"name\":\"2670916218\",\"rule_id\":\"default\",\"secon